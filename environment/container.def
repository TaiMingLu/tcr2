# Minimal container definition using ubuntu:22.04 base.
# CUDA runtime should already be available on GPU nodes.
# The nvidia/cuda image is needed only for CUDA development; for runtime,
# ubuntu base + existing GPU drivers is sufficient.

Bootstrap: docker
From: ubuntu:22.04

%post
    apt-get update && apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python3-dev \
        libomp-dev \
        libgl1-mesa-glx \
        libglib2.0-0 \
        tmux \
        nano \
        vim-tiny \
        less \
        curl \
        wget \
        git \
        ca-certificates \
        && rm -rf /var/lib/apt/lists/*

    ln -sf /usr/bin/python3 /usr/bin/python
    ln -sf /usr/bin/pip3 /usr/bin/pip

    mkdir -p /home/user/data
    chmod 755 /home/user

%environment
    export HOME=/home/user
    export PYTHONUNBUFFERED=1
    export HF_HOME=/home/user/shared/hf_cache
    export TRANSFORMERS_CACHE=/home/user/shared/hf_cache
    export PYTHONPATH="/home/user/pylibs:/home/user:$PYTHONPATH"
