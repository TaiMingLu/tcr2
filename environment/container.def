# Apptainer definition file for TCR reasoning hop generalization environment.
#
# Build:  apptainer build container.sif container.def
#
# The container packages everything a scientist agent needs to work on
# this paper's task. The agent's workspace is bind-mounted at /home/user
# at runtime — it is NOT baked into the container.

Bootstrap: docker
From: nvidia/cuda:12.1.0-runtime-ubuntu22.04

%post
    apt-get update && apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python3-dev \
        libomp-dev \
        libgl1-mesa-glx \
        libglib2.0-0 \
        tmux \
        nano \
        vim-tiny \
        less \
        curl \
        wget \
        git \
        ca-certificates \
        && rm -rf /var/lib/apt/lists/*

    ln -sf /usr/bin/python3 /usr/bin/python
    ln -sf /usr/bin/pip3 /usr/bin/pip

    # Install uv (fast package installer)
    curl -LsSf https://astral.sh/uv/install.sh | sh
    ln -sf /root/.local/bin/uv /usr/local/bin/uv

    mkdir -p /home/user/data
    chmod 755 /home/user

%environment
    export HOME=/home/user
    export PYTHONUNBUFFERED=1
    export CUDA_VISIBLE_DEVICESICES=""  # Let Ray manage GPU allocation
