# Container definition for TCR reproduction.
# Uses ubuntu:22.04 base. GPU nodes have nvidia drivers + CUDA runtime pre-installed.
# Python packages are pre-cached in /home/user/pylibs and accessed via PYTHONPATH.

Bootstrap: docker
From: ubuntu:22.04

%post
    apt-get update && apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python3-dev \
        libomp-dev \
        libgl1-mesa-glx \
        libglib2.0-0 \
        tmux \
        nano \
        vim-tiny \
        less \
        curl \
        wget \
        git \
        ca-certificates \
        && rm -rf /var/lib/apt/lists/*

    ln -sf /usr/bin/python3 /usr/bin/python
    ln -sf /usr/bin/pip3 /usr/bin/pip

    mkdir -p /home/user/data
    chmod 755 /home/user


    # --- Merged from setup.sh ---
    pip install --break-system-packages uv 2>/dev/null || pip install uv 2>/dev/null || true
    export UV_SYSTEM_PYTHON=1 UV_BREAK_SYSTEM_PACKAGES=1
    # Install Python packages into the container overlay.
    # uv is pre-installed in the base CUDA container.
    
    set -e
    
    echo "=== Installing Python packages for TCR environment ==="
    
    # Install core packages - these are cached locally in /home/user/pylibs
    # but we reinstall to ensure they're in the system Python
    uv pip install --system \
        torch \
        numpy \
        scipy \
        scikit-learn \
        transformers \
        huggingface_hub \
        accelerate \
        peft \
        tqdm
    
    echo "=== Package installation complete ==="

%environment
    export HOME=/home/user
    export PYTHONUNBUFFERED=1
    export HF_HOME=/home/user/shared/hf_cache
    export TRANSFORMERS_CACHE=/home/user/shared/hf_cache
    export PYTHONPATH="/home/user/pylibs:/home/user:$PYTHONPATH"
