# Large files — do not commit (applies everywhere, including tmp/)
checkpoints/
*.pt
*.pth
*.ckpt
*.safetensors
*.bin
*.npy
*.npz
*.h5
*.hdf5
*.pkl
*.pickle
*.parquet
*.arrow
*.tar
*.tar.gz
*.tgz
*.zip
*.gz
*.onnx
*.gguf
*.msgpack
*.tflite
*.pb

# Files too large for git: public fetched data (datasets, weights) and
# agent-generated data that exceeds git's size limit. Repopulated from
# scratch by scripts/download.sh. Everything else under data/ IS tracked.
data/downloads/
!data/downloads/.gitkeep

# Container artifacts (multi-GB)
environment/container.sif
environment/container.squashfs
environment/overlay*.img
environment/.setup_wrapper.sh
environment/.overlay.log
*.squashfs
*.sif
*.img

# Container sandbox / rootfs extracts (agents sometimes build these inside environment/ — 100s of GB)
.apptainer/
.apptainer_tmp/
.apptainer_tools/
.singularity/
environment/container_sandbox/
environment/*sandbox*/
environment/sandbox*/
environment/rootfs*/
environment/*-rootfs*
environment/*.tar.gz
environment/*.tar

